#!/bin/bash\
# ==========================================\
# DIGITAL OPS AUTONOMOUS AGENT BUILDER\
# ==========================================\
\
mkdir -p ~/DigitalOps-Agent\
cd ~/DigitalOps-Agent\
\
echo "Initializing Agent Workspace..."\
\
# 1. Create Python Requirements\
cat << 'EOF' > requirements.txt\
langchain>=0.2.0\
langchain-openai>=0.1.0\
langgraph>=0.0.60\
langchain-core>=0.2.0\
huggingface-hub>=0.23.0\
google-cloud-storage\
python-dotenv\
colorama\
EOF\
\
# 2. Create the Dockerfile with Cloud SDKs\
cat << 'EOF' > Dockerfile\
FROM python:3.11-slim\
\
# Install system dependencies, GitHub CLI, and Cloud tools\
RUN apt-get update && apt-get install -y curl git jq nano wget gnupg software-properties-common apt-transport-https ca-certificates\
\
# Install Google Cloud SDK\
RUN echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" | tee -a /etc/apt/sources.list.d/google-cloud-sdk.list && \\\
    curl https://packages.cloud.google.com/apt/doc/apt-key.gpg | apt-key --keyring /usr/share/keyrings/cloud.google.gpg add - && \\\
    apt-get update -y && apt-get install google-cloud-sdk -y\
\
# Install GitHub CLI\
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \\\
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \\\
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" | tee /etc/apt/sources.list.d/github-cli.list > /dev/null && \\\
    apt-get update && apt-get install gh -y\
\
WORKDIR /agent\
COPY requirements.txt .\
RUN pip install --no-cache-dir -r requirements.txt\
\
COPY . .\
\
# Keep container alive and drop into the agent\
CMD ["python", "agent.py"]\
EOF\
\
# 3. Create the Autonomous Agent Logic\
cat << 'EOF' > agent.py\
import os\
import subprocess\
from colorama import Fore, Style, init\
from langchain_openai import ChatOpenAI\
from langchain_core.messages import HumanMessage\
from langgraph.prebuilt import create_react_agent\
from langchain_core.tools import tool\
\
init(autoreset=True)\
\
# ================= TOOLS =================\
@tool\
def execute_terminal(command: str) -> str:\
    """Execute a terminal command. Crucial for gcloud, git, huggingface-cli, and bash operations."""\
    print(f"\{Fore.YELLOW\}[AGENT EXECUTING]: \{command\}\{Style.RESET_ALL\}")\
    try:\
        result = subprocess.run(command, shell=True, text=True, capture_output=True, timeout=300)\
        output = f"STDOUT:\\n\{result.stdout\}\\nSTDERR:\\n\{result.stderr\}"\
        return output if output.strip() else "Command executed successfully with no output."\
    except Exception as e:\
        return f"Error executing command: \{str(e)\}"\
\
@tool\
def write_file(filepath: str, content: str) -> str:\
    """Write configuration files, code, or scripts to the filesystem."""\
    try:\
        with open(filepath, 'w') as f:\
            f.write(content)\
        return f"Successfully wrote to \{filepath\}"\
    except Exception as e:\
        return f"Failed to write file: \{str(e)\}"\
\
@tool\
def read_file(filepath: str) -> str:\
    """Read the contents of a file to analyze configurations or code."""\
    try:\
        with open(filepath, 'r') as f:\
            return f.read()\
    except Exception as e:\
        return f"Failed to read file: \{str(e)\}"\
\
# ================= AGENT SETUP =================\
def setup_agent():\
    # Uses GPT-4o for ultra-intelligent tool calling (can be swapped to Claude/Gemini)\
    llm = ChatOpenAI(model="gpt-4o", temperature=0.1)\
    tools = [execute_terminal, write_file, read_file]\
    \
    system_prompt = """You are an elite, autonomous AI-First Digital Ops Agent. \
Your primary purpose is personal administration, account management, and setting up/configuring developer and AI platforms (Google Cloud, Hugging Face, GitHub, Docker, etc.).\
You have root shell access within this container via the `execute_terminal` tool. \
When given a command, you will autonomously write files, run CLIs (like `gcloud` or `huggingface-cli`), handle errors, and execute steps sequentially until the platform/software is fully configured and ready to run. \
Do not ask for permission to run commands\'97just do it, verify the output, and proceed."""\
\
    return create_react_agent(llm, tools, state_modifier=system_prompt)\
\
# ================= MAIN LOOP =================\
def main():\
    agent = setup_agent()\
    print(f"\{Fore.CYAN\}====================================================\{Style.RESET_ALL\}")\
    print(f"\{Fore.CYAN\} AI DIGITAL OPS AGENT IS ONLINE AND AWAITING COMMANDS \{Style.RESET_ALL\}")\
    print(f"\{Fore.CYAN\}====================================================\{Style.RESET_ALL\}")\
    \
    while True:\
        try:\
            user_input = input(f"\\n\{Fore.GREEN\}Ops Command > \{Style.RESET_ALL\}")\
            if user_input.lower() in ['exit', 'quit']:\
                break\
                \
            inputs = \{"messages": [HumanMessage(content=user_input)]\}\
            for chunk in agent.stream(inputs, stream_mode="values"):\
                message = chunk["messages"][-1]\
                if message.content:\
                    print(f"\\n\{Fore.MAGENTA\}Agent Response:\{Style.RESET_ALL\} \{message.content\}")\
        \
        except KeyboardInterrupt:\
            break\
        except Exception as e:\
            print(f"\{Fore.RED\}System Error: \{e\}\{Style.RESET_ALL\}")\
\
if __name__ == "__main__":\
    main()\
EOF\
\
# 4. Create the Environment File Template\
cat << 'EOF' > .env\
# Set your OpenAI API Key here (Required for the Agent's Brain)\
OPENAI_API_KEY=your_openai_api_key_here\
\
# Optional: Add any other keys you want the agent to have immediate access to\
HUGGING_FACE_HUB_TOKEN=your_hf_token_here\
GITHUB_TOKEN=your_github_token_here\
EOF\
\
# 5. Create Auto-Start Script\
cat << 'EOF' > start.sh\
#!/bin/bash\
echo "Building Agent Container..."\
docker build -t digital-ops-agent .\
\
echo "Starting Agent Environment..."\
# Run interactive container, mounting the current directory, passing the .env file\
docker run -it --rm \\\
    --env-file .env \\\
    -v $(pwd)/workspace:/agent/workspace \\\
    -v ~/.config/gcloud:/root/.config/gcloud \\\
    digital-ops-agent\
EOF\
chmod +x start.sh\
\
mkdir -p workspace\
\
echo "=========================================================="\
echo "\uc0\u9989  DEPLOYMENT COMPLETE! YOUR AGENT IS READY."\
echo "=========================================================="\
echo "To wake up your agent:"\
echo "1. Go to your new folder: cd ~/DigitalOps-Agent"\
echo "2. Edit the .env file and paste your OPENAI_API_KEY"\
echo "3. Run the auto-start script: ./start.sh"\
\
}