{
  "version": 2,
  "buildCommand": "pnpm run build",
  "devCommand": "pnpm run dev",
  "installCommand": "pnpm install",
  "framework": null,
  "outputDirectory": "dist/public",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x@20"
    }
  },
  "routes": [
    {
      "src": "/api/trpc(.*)",
      "dest": "/api/trpc.ts"
    }
  ]
}
